#!/usr/bin/env bash
# mcp-agent — Ollama-style launcher for the MCP agent.
# Installed to /usr/local/bin/mcp-agent by install.sh.
#
# Commands:
#   mcp-agent [run]    start service if needed, wait for health, print API usage
#   mcp-agent serve    run the server in the foreground (no systemd)
#   mcp-agent start    systemctl start mcp-agent
#   mcp-agent stop     systemctl stop mcp-agent
#   mcp-agent restart  systemctl restart mcp-agent
#   mcp-agent status   systemctl status mcp-agent
#   mcp-agent logs     journalctl -u mcp-agent -f
#   mcp-agent config   re-prompt for key/Redis, rewrite agent.env, restart service
#   mcp-agent uninstall  remove service + launcher (prompts before deleting AGENT_HOME)
set -euo pipefail

AGENT_HOME="${AGENT_HOME:-$HOME/.mcp-agent}"
ENV_FILE="$AGENT_HOME/agent.env"
CONFIG_YML="$AGENT_HOME/config/application.yml"

# ── helpers ──────────────────────────────────────────────────────────────────
info()    { printf '\033[1;34m[mcp-agent]\033[0m %s\n' "$*"; }
success() { printf '\033[1;32m[mcp-agent]\033[0m %s\n' "$*"; }
warn()    { printf '\033[1;33m[mcp-agent]\033[0m %s\n' "$*"; }
die()     { printf '\033[1;31m[mcp-agent]\033[0m %s\n' "$*" >&2; exit 1; }

load_env() {
  if [[ -f "$ENV_FILE" ]]; then
    # Export only non-comment, non-empty lines
    # shellcheck disable=SC2046
    export $(grep -v '^\s*#' "$ENV_FILE" | grep -v '^\s*$' | xargs)
  fi
}

wait_for_health() {
  local timeout="${1:-30}"
  local elapsed=0
  until curl -sf http://localhost:8080/actuator/health >/dev/null 2>&1; do
    elapsed=$((elapsed + 1))
    if [[ $elapsed -ge $timeout ]]; then
      warn "Server did not respond within ${timeout}s."
      warn "Check: mcp-agent logs"
      return 1
    fi
    sleep 1
  done
  return 0
}

# ── subcommands ───────────────────────────────────────────────────────────────
cmd_run() {
  load_env

  # Ensure the service is running
  if ! systemctl is-active --quiet mcp-agent 2>/dev/null; then
    info "Starting mcp-agent service..."
    sudo systemctl start mcp-agent
  fi

  info "Waiting for agent server..."
  if ! wait_for_health 30; then
    return 1
  fi
  success "Server ready on http://localhost:8080"

  local auth_hint=""
  [[ -n "${AGENT_API_KEY:-}" ]] && auth_hint='-H "X-API-Key: $AGENT_API_KEY" '

  cat <<MSG

Send a prompt to the agent:
  curl -X POST http://localhost:8080/api/agent/chat \\
    -H "Content-Type: application/json" ${auth_hint}\\
    -d '{"prompt": "Hello!"}'

Stream the response (Server-Sent Events):
  curl -N -X POST http://localhost:8080/api/agent/stream \\
    -H "Content-Type: application/json" -H "Accept: text/event-stream" ${auth_hint}\\
    -d '{"prompt": "Hello!"}'

Service status/logs:  mcp-agent status  |  mcp-agent logs
MSG
}

cmd_serve() {
  load_env
  exec java -jar "$AGENT_HOME/bin/mcp-integration.jar" \
    "--spring.config.additional-location=file:${CONFIG_YML}"
}

cmd_start()   { sudo systemctl start   mcp-agent; }
cmd_stop()    { sudo systemctl stop    mcp-agent; }
cmd_restart() { sudo systemctl restart mcp-agent; }
cmd_status()  { systemctl status       mcp-agent; }
cmd_logs()    { exec journalctl -u mcp-agent -f; }

cmd_config() {
  [[ -f "$ENV_FILE" ]] && load_env

  # Re-prompt for API key
  local new_key=""
  while [[ -z "$new_key" ]]; do
    read -rsp "OpenRouter API key (sk-or-v1-...) [current hidden]: " new_key; echo
    [[ -z "$new_key" ]] && warn "Key is required. Try again."
  done

  # Re-prompt for Redis
  read -rp "Redis host for long-term memory (leave blank to disable): " redis_host_input
  local memory_enabled=false redis_host_val="" redis_port_val=6379
  if [[ -n "$redis_host_input" ]]; then
    memory_enabled=true
    redis_host_val="$redis_host_input"
    read -rp "Redis port [6379]: " redis_port_input
    redis_port_val="${redis_port_input:-6379}"
  fi

  cat > "$ENV_FILE" <<EOF
OPEN_ROUTER_API_KEY=${new_key}
MEMORY_ENABLED=${memory_enabled}
REDIS_HOST=${redis_host_val}
REDIS_PORT=${redis_port_val}
# AGENT_API_KEY=                 # uncomment + set to require X-API-Key on /api/agent/**
EOF
  chmod 600 "$ENV_FILE"
  success "agent.env updated."

  if systemctl is-active --quiet mcp-agent 2>/dev/null; then
    info "Restarting service..."
    sudo systemctl restart mcp-agent
    if wait_for_health 30; then
      success "Service restarted and healthy."
    fi
  fi
}

cmd_uninstall() {
  # Delegate to the original install.sh --uninstall if present, otherwise inline
  local repo_install
  repo_install="$(dirname "$(readlink -f "$0")" 2>/dev/null || echo "")"

  info "Stopping and removing mcp-agent service..."
  sudo systemctl disable --now mcp-agent 2>/dev/null || true
  sudo rm -f /etc/systemd/system/mcp-agent.service
  sudo systemctl daemon-reload
  sudo rm -f /usr/local/bin/mcp-agent
  success "Service and launcher removed."

  if [[ -d "$AGENT_HOME" ]]; then
    read -rp "Delete $AGENT_HOME (contains workspace + config)? [y/N] " confirm
    if [[ "${confirm,,}" == "y" ]]; then
      rm -rf "$AGENT_HOME"
      success "$AGENT_HOME deleted."
    else
      info "Kept $AGENT_HOME."
    fi
  fi
}

# ── dispatch ──────────────────────────────────────────────────────────────────
CMD="${1:-run}"
shift || true

case "$CMD" in
  run)       cmd_run       ;;
  serve)     cmd_serve     ;;
  start)     cmd_start     ;;
  stop)      cmd_stop      ;;
  restart)   cmd_restart   ;;
  status)    cmd_status    ;;
  logs)      cmd_logs      ;;
  config)    cmd_config    ;;
  uninstall) cmd_uninstall ;;
  *)
    cat <<USAGE
Usage: mcp-agent [command]

Commands:
  (none) / run   Start service if needed, wait for health, print API usage
  serve          Run the server in the foreground (no systemd)
  start          Start the background service
  stop           Stop the background service
  restart        Restart the background service
  status         Show service status
  logs           Stream service logs (journalctl)
  config         Reconfigure API key / Redis, restart service
  uninstall      Remove service, launcher, and optionally AGENT_HOME
USAGE
    exit 1
    ;;
esac
