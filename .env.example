# ──────────────────────────────────────────────────────────────────────────────
# Hugin — environment configuration for the Docker quickstart.
#
#   cp .env.example .env   then edit the values below and run `docker compose up --build`.
#
# This file is read by docker-compose.yml. Do NOT commit your filled-in .env
# (it is gitignored) and never bake real keys into the image.
# ──────────────────────────────────────────────────────────────────────────────

# ── LLM provider ──────────────────────────────────────────────────────────────
# Hugin talks to any OpenAI-compatible chat endpoint. Pick a provider below and
# supply the matching API key. At least one key is required for the agent to chat.

# OpenRouter key (sk-or-v1-...). Used when LLM_PROVIDER=openrouter (the default).
OPEN_ROUTER_API_KEY=

# OpenAI key (sk-...). Used when LLM_PROVIDER=openai.
OPENAI_API_KEY=

# Active provider: openrouter | openai | ollama
LLM_PROVIDER=openrouter

# Default model. Must be valid for the active provider and support tool calling.
#   openrouter -> openai/gpt-oss-120b
#   openai     -> gpt-4o-mini
LLM_MODEL=openai/gpt-oss-120b

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
# These are consumed both by the postgres service (to create the DB/role) and by
# the app. SPRING_DATASOURCE_URL is set in docker-compose.yml to reach the
# postgres service, so you do not need to set a JDBC URL here.
SPRING_DATASOURCE_DB=hugin
SPRING_DATASOURCE_USERNAME=hugin
SPRING_DATASOURCE_PASSWORD=hugin

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ── Agent runtime ─────────────────────────────────────────────────────────────
# Base-of-operations directory inside the container (backed by a named volume).
AGENT_HOME=/home/hugin/.hugin

# Per-session Docker sandboxes execute agent shell commands inside Docker containers, and the
# docker-compose.sandbox.yml override additionally mounts the host Docker socket (which grants the
# container control of the host Docker daemon). This is powerful — only enable it on trusted
# local/self-hosted machines. Keep this false for the default setup.
SANDBOX_ENABLED=false

# ── Authentication ────────────────────────────────────────────────────────────
# Bootstrap login created on first startup.
#
# SECURITY: the app refuses to start when AUTH_BOOTSTRAP_PASSWORD is blank or a well-known weak
# value (change-me, admin, password, ...), UNLESS AUTH_BOOTSTRAP_ALLOW_INSECURE_PASSWORD=true.
# The values below are for the localhost quickstart only. Before exposing Hugin beyond localhost,
# set a strong, unique AUTH_BOOTSTRAP_PASSWORD and leave AUTH_BOOTSTRAP_ALLOW_INSECURE_PASSWORD unset
# (defaults to false).
AUTH_BOOTSTRAP_USERNAME=admin
AUTH_BOOTSTRAP_PASSWORD=change-me
AUTH_BOOTSTRAP_ALLOW_INSECURE_PASSWORD=true

# ── Optional ──────────────────────────────────────────────────────────────────
# Reasoning effort sent to providers that support it: low | medium | high
# LLM_REASONING_EFFORT=medium
#
# Enable Redis-backed long-term memory (off by default).
# MEMORY_ENABLED=false
#
# Vision model the describe_image tool forwards attached images to (via OpenRouter,
# using OPEN_ROUTER_API_KEY above). The default chat model is text-only, so image
# attachments are described by this vision-capable model instead.
# IMAGE_DESCRIBE_MODEL=openai/gpt-4o-mini
#
# Search-backed tools (web_search and deep_research) use a Perplexity Sonar model via
# OpenRouter. WEB_SEARCH_MODEL applies to both; set RESEARCH_MODEL to give the multi-search
# deep_research tool its own (e.g. a more thorough) default model. Both require OPEN_ROUTER_API_KEY.
# A user can also pick a research model in Settings, which overrides RESEARCH_MODEL per request.
# WEB_SEARCH_MODEL=perplexity/sonar
# RESEARCH_MODEL=perplexity/sonar
