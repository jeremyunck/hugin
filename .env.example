# ──────────────────────────────────────────────────────────────────────────────
# Bouw — environment configuration for the Docker quickstart.
#
#   cp .env.example .env   then edit the values below and run `docker compose up --build`.
#
# This file is read by docker-compose.yml. Do NOT commit your filled-in .env
# (it is gitignored) and never bake real keys into the image.
# ──────────────────────────────────────────────────────────────────────────────

# ── LLM provider ──────────────────────────────────────────────────────────────
# Bouw talks to any OpenAI-compatible chat endpoint. Pick a provider below and
# supply the matching API key. At least one key is required for the agent to chat.

# OpenRouter key (sk-or-v1-...). Used when LLM_PROVIDER=openrouter (the default).
# Acts as a server-wide fallback; individual users can also save their own key in
# their account, which is encrypted at rest and used (and billed) for their sessions.
OPEN_ROUTER_API_KEY=

# Secret used to encrypt user-supplied credentials (per-user OpenRouter keys and MCP
# bearer tokens) at rest. Set this to a stable, high-entropy value in production —
# changing or losing it makes previously stored secrets undecryptable. BOUW_SECRET_KEY
# is accepted as an alias (APP_ENCRYPTION_SECRET takes precedence if both are set).
APP_ENCRYPTION_SECRET=
BOUW_SECRET_KEY=

# --- MCP (Model Context Protocol) ---
# stdio transport runs MCP servers as local child processes. SECURITY: keep this false on shared
# multi-user hosts (it lets users run commands on the server); enable only for self-hosted/single-user.
# Optionally restrict launchable commands with a comma-separated allow-list.
MCP_STDIO_ENABLED=false
MCP_STDIO_ALLOWED_COMMANDS=
# OAuth callback base URL. Leave blank to derive from the request; set it when behind a proxy so the
# redirect_uri matches what the authorization server expects (e.g. https://bouw.example.com).
MCP_OAUTH_REDIRECT_BASE_URL=

# OpenAI key (sk-...). Used when LLM_PROVIDER=openai.
OPENAI_API_KEY=

# Active provider: openrouter | openai | ollama
LLM_PROVIDER=openrouter

# Default model. Must be valid for the active provider and support tool calling.
#   openrouter -> openai/gpt-oss-120b
#   openai     -> gpt-4o-mini
LLM_MODEL=openai/gpt-oss-120b

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
# These are consumed both by the postgres service (to create the DB/role) and by
# the app. SPRING_DATASOURCE_URL is set in docker-compose.yml to reach the
# postgres service, so you do not need to set a JDBC URL here.
SPRING_DATASOURCE_DB=bouw
SPRING_DATASOURCE_USERNAME=bouw
SPRING_DATASOURCE_PASSWORD=bouw

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ── Agent runtime ─────────────────────────────────────────────────────────────
# Base-of-operations directory inside the container (backed by a named volume).
AGENT_HOME=/home/bouw/.bouw

# Per-session Docker sandboxes execute agent shell commands inside Docker containers, and the
# docker-compose.sandbox.yml override additionally mounts the host Docker socket (which grants the
# container control of the host Docker daemon). This is powerful — only enable it on trusted
# local/self-hosted machines. Keep this false for the default setup.
SANDBOX_ENABLED=false

# ── Networking ───────────────────────────────────────────────────────────────
# Host port the Bouw container is published on. Defaults to 8080 (the standard
# deployment port). Override here only if 8080 is already occupied on the host,
# e.g. when an agent is running this stack inside a sandbox alongside a
# natively-installed Bouw. The container always listens on 8080 internally;
# only the host-side binding changes.
# HOST_PORT=8081

# ── Authentication ────────────────────────────────────────────────────────────
# Bootstrap login created on first startup.
#
# SECURITY: the app refuses to start when AUTH_BOOTSTRAP_PASSWORD is blank or a well-known weak
# value (change-me, admin, password, ...), UNLESS AUTH_BOOTSTRAP_ALLOW_INSECURE_PASSWORD=true.
# The values below are for the localhost quickstart only. Before exposing Bouw beyond localhost,
# set a strong, unique AUTH_BOOTSTRAP_PASSWORD and leave AUTH_BOOTSTRAP_ALLOW_INSECURE_PASSWORD unset
# (defaults to false).
AUTH_BOOTSTRAP_USERNAME=admin
AUTH_BOOTSTRAP_PASSWORD=change-me
AUTH_BOOTSTRAP_ALLOW_INSECURE_PASSWORD=true

# ── Email verification (Resend) ───────────────────────────────────────────────
# Registration and login both email the user a one-time 6-digit code that must be confirmed before a
# session is issued. Codes are delivered via Resend (https://resend.com). Create an API key and verify
# a sending domain/address, then set both values below.
#
# When RESEND_API_KEY is blank, Bouw logs the code at WARN instead of emailing it. If RESEND_FROM is
# omitted, Bouw defaults to Resend's onboarding sender (`onboarding@resend.dev`) for test-only flows.
# Do NOT rely on that sender for any shared deployment or non-test recipient.
RESEND_API_KEY=
# Verified sender, e.g. "Bouw <login@yourdomain.com>"
RESEND_FROM=

# ── Optional ──────────────────────────────────────────────────────────────────
# Reasoning effort sent to providers that support it: low | medium | high
# LLM_REASONING_EFFORT=medium
#
# Enable Redis-backed long-term memory (off by default).
# MEMORY_ENABLED=false
#
# Vision model the describe_image tool forwards attached images to (via OpenRouter,
# using OPEN_ROUTER_API_KEY above). The default chat model is text-only, so image
# attachments are described by this vision-capable model instead.
# IMAGE_DESCRIBE_MODEL=openai/gpt-4o-mini
#
# Search-backed tools (web_search and deep_research) use a Perplexity Sonar model via
# OpenRouter. WEB_SEARCH_MODEL applies to both; set RESEARCH_MODEL to give the multi-search
# deep_research tool its own (e.g. a more thorough) default model. Both require OPEN_ROUTER_API_KEY.
# A user can also pick a research model in Settings, which overrides RESEARCH_MODEL per request.
# WEB_SEARCH_MODEL=perplexity/sonar
# RESEARCH_MODEL=perplexity/sonar
