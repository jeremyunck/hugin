{
  "mcpServers": {
    "filesystem": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "/tmp"],
      "env": {}
    },
    "time": {
      "command": "uvx",
      "args": ["mcp-server-time"],
      "env": {}
    },
    "browser": {
      "command": "python3",
      "args": ["browser-mcp/server.py"],
      "env": {}
    }
  }
}
